# Supabase project (publishable values — safe for the client bundle)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Continuity GraphQL endpoint. Must be reachable from the device/emulator.
# Use the deployed backend, not http://localhost:8000 (unreachable from a device).
EXPO_PUBLIC_GRAPHQL_URL=https://continuity-backend.onrender.com/graphql/
